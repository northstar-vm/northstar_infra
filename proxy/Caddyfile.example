{
	email YOUR_REAL_EMAIL
}

# Existing Quizzy app.
# Keep your current working block here when applying this template.
# The app compose has backend, frontend, and web services; the web/nginx service
# exposes the app on server port 8080 in the current deployment.
quizzy.attentionisallineed.xyz {
	reverse_proxy EXISTING_WORKING_QUIZZY_UPSTREAM
}

attentionisallineed.xyz {
	redir https://cv.attentionisallineed.xyz{uri}
}

www.attentionisallineed.xyz {
	redir https://cv.attentionisallineed.xyz{uri}
}

cv.attentionisallineed.xyz {
	encode zstd gzip
	reverse_proxy cv-web:80
}

northstar.attentionisallineed.xyz {
	basic_auth {
		vallutto ADMIN_PASSWORD_HASH_FROM_CADDY
	}

	encode zstd gzip

	handle_path /docker/* {
		reverse_proxy portainer:9000
	}

	redir /docker /docker/

	handle /files/* {
		reverse_proxy filebrowser:80 {
			header_up -Authorization
		}
	}

	redir /files /files/

	handle_path /status/* {
		reverse_proxy status:8080
	}

	handle {
		root * /srv/northstar-admin
		file_server
	}
}
